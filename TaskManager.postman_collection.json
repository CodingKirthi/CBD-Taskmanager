{
  "info": {
    "name": "Task Manager API",
    "_postman_id": "cbd-assignment-2",
    "description": "Full API collection for the Task Manager Spring Boot application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My First Project\",\n  \"description\": \"A project to manage my tasks\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"]
            },
            "description": "Creates a new project. Name must be unique."
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"]
            },
            "description": "Returns all projects sorted by name."
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "1"]
            },
            "description": "Returns a single project by its ID. Change 1 to any project ID."
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/projects/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "1"]
            },
            "description": "Deletes a project. Will return 409 if the project has IN_PROGRESS tasks."
          }
        },
        {
          "name": "Create Duplicate Project (409 Error Demo)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My First Project\",\n  \"description\": \"This will fail - name already exists\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"]
            },
            "description": "Tries to create a project with a duplicate name. Expect 409 Conflict."
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Task\",\n  \"description\": \"A task for my project\",\n  \"priority\": \"HIGH\",\n  \"dueDate\": \"2026-12-31\",\n  \"projectId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Creates a new task. priority options: LOW, MEDIUM, HIGH, CRITICAL"
          }
        },
        {
          "name": "Create Critical Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fix Critical Bug\",\n  \"description\": \"This is urgent!\",\n  \"priority\": \"CRITICAL\",\n  \"projectId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Creates a CRITICAL priority task."
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "1"]
            },
            "description": "Returns a single task by ID."
          }
        },
        {
          "name": "Get Tasks by Project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/project/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "project", "1"]
            },
            "description": "Returns all tasks belonging to project ID 1."
          }
        },
        {
          "name": "Get Critical Open Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/critical",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "critical"]
            },
            "description": "Returns all CRITICAL priority tasks that are not yet DONE."
          }
        },
        {
          "name": "Update Status → IN_PROGRESS",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/1/status?status=IN_PROGRESS",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "1", "status"],
              "query": [{ "key": "status", "value": "IN_PROGRESS" }]
            },
            "description": "Moves task 1 to IN_PROGRESS status."
          }
        },
        {
          "name": "Update Status → DONE",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/1/status?status=DONE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "1", "status"],
              "query": [{ "key": "status", "value": "DONE" }]
            },
            "description": "Completes task 1. The completedAt timestamp will be set automatically."
          }
        },
        {
          "name": "Update Status → BLOCKED",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/1/status?status=BLOCKED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "1", "status"],
              "query": [{ "key": "status", "value": "BLOCKED" }]
            },
            "description": "Marks task 1 as BLOCKED."
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/tasks/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "1"]
            },
            "description": "Deletes task 1."
          }
        },
        {
          "name": "Create Task - Past Due Date (400 Error Demo)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Late Task\",\n  \"description\": \"This will fail - due date is in the past\",\n  \"priority\": \"LOW\",\n  \"dueDate\": \"2020-01-01\",\n  \"projectId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Tries to create a task with a past due date. Expect 409 Conflict."
          }
        },
        {
          "name": "Create Task - Missing Title (400 Error Demo)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"priority\": \"MEDIUM\",\n  \"projectId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Tries to create a task with a blank title. Expect 400 Bad Request."
          }
        }
      ]
    }
  ]
}
